# ==============================================================================
# J.R Hortifruti Delivery — Template de Variáveis de Ambiente (.env.example)
# ==============================================================================
# Instruções:
# 1. Copie este arquivo e renomeie a cópia para ".env" (ou ".env.local").
# 2. Preencha os valores reais correspondentes.
# 3. O arquivo ".env" está configurado no ".gitignore" e NUNCA deve ser commitado.
# ==============================================================================

# --- CONFIGURAÇÃO DE ATENDIMENTO ---
# Número oficial do WhatsApp para receber os pedidos formatados do carrinho (DDI + DDD + Número)
# Exemplo: 5521969035431
WHATSAPP_PEDIDOS=5521969035431

# --- CONFIGURAÇÃO DE RASTREAMENTO E ANALYTICS ---
# Chave de acompanhamento do Google Analytics (ex: UA-XXXXXXX-Y ou G-XXXXXXX)
GOOGLE_ANALYTICS_ID=seu_google_analytics_id_aqui

# ID da conta do Hotjar para gravação de sessões e mapas de calor de comportamento
HOTJAR_ID=seu_hotjar_id_aqui
